# Local development (Vite reads these at `npm run dev` / `npm run build`)
VITE_API_BASE_URL=http://localhost:8080

# Docker production build (values are baked into the static bundle at build time):
#   docker build \
#     --build-arg VITE_API_BASE_URL=https://api.yourdomain.com \
#     -t chemverify-client .
