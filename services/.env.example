# Flask / RAG service environment variables

# MongoDB (primary RAG database)
MONGO_URI=mongodb://localhost:27017

# MongoDB (ingredient / formulation mappings)
MONGO_URI_2=mongodb://localhost:27017

# LLM (Groq)
GROQ_API_KEY=

# Embeddings (Hugging Face Inference API)
HF_API_KEY=

# Gunicorn listen port (used by the production Dockerfile)
PORT=5000

# Optional comma-separated extra CORS origins (browser clients)
# CORS_ALLOWED_ORIGINS=https://chemverify.deployio.tech

# Docker example:
#   docker build -t chemverify-services ./services
#   docker run --env-file ./services/.env -p 5000:5000 chemverify-services
